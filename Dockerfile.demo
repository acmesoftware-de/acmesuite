# Minimal runtime image for the demo.acmesoftware.de deployment. Assumes the jar was already
# built locally/in CI (`mvn -DskipTests package`) — not a multi-stage build, to avoid needing
# a full JDK/Maven toolchain on the deploy target.
FROM eclipse-temurin:25-jre-alpine
WORKDIR /app
COPY target/acmesuite-0.1.0-SNAPSHOT.jar app.jar
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]
